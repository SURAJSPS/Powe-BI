# Copy to `.env` in the project root. Do not commit real secrets.

# ─── Option A: full URI (any one name) ─────────────────────────────────────
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# MONGODB_URI=  (same idea, alias)

# ─── Option B: RNK / Streamlit variable names ──────────────────────────────
# MONGO_USER=
# MONGO_PASSWORD=
# MONGO_HOST=cluster0.xxxxx.mongodb.net
# MONGO_APP_NAME=Cluster0
# MONGO_AUTH_SOURCE=admin
# MONGO_DB_NAME=rnk_civil

# ─── Option C: same as Node / Tepo API (.env) ──────────────────────────────
# MONGODB_USERNAME=
# MONGODB_PASSWORD=
# MONGODB_CLUSTER=cluster0.xxxxx.mongodb.net
# MONGODB_DATABASE=tepo
# MONGODB_APP_NAME=Cluster0
# MONGODB_AUTH_SOURCE=admin

# JWT / PORT / CORS / etc. from your API stack are ignored by this Streamlit app.
