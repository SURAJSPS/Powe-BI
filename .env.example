# Copy to `.env` in this folder. Do not commit real secrets.

# --- Option A: full connection string (Atlas → Connect → Drivers) ---
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# --- Option B: split variables (password special chars are OK; they are URL-encoded) ---
MONGO_USER=
MONGO_PASSWORD=
# Host only, e.g. cluster0.abcd123.mongodb.net (no mongodb+srv:// prefix)
MONGO_HOST=

# Optional: mongodb+srv (Atlas) or mongodb
# MONGO_SCHEME=mongodb+srv

# Optional: app name shown in Atlas logs
# MONGO_APP_NAME=Cluster0

# Optional: auth DB if your host requires it (usually not needed on Atlas)
# MONGO_AUTH_SOURCE=admin

# Database name used by the app
MONGO_DB_NAME=rnk_civil
