# =============================================================================
# Copy this file to `.env` in the SAME folder (repository root) and fill values.
# The Streamlit app loads ONLY this file:  Powe-BI/.env
# Do not commit `.env` (real secrets). This example is safe to commit.
# =============================================================================

# --- MongoDB (required for python_app / Streamlit) — Tepo-style names ---
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_CLUSTER=
MONGODB_DATABASE=tepo
MONGODB_APP_NAME=Cluster0
MONGODB_AUTH_SOURCE=admin

# Optional: full URI instead of the fields above (then leave username/password empty or omit)
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# Optional aliases also supported: MONGO_URI, MONGO_USER, MONGO_PASSWORD, MONGO_HOST, MONGO_DB_NAME

# --- Everything below is ignored by Streamlit; safe to share file with Node API ---
# NODE_ENV=production
# PORT=5001
# JWT_ACCESS_SECRET=
# ALLOWED_ORIGINS=
